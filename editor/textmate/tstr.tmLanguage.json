{
  "name": "tstr",
  "scopeName": "source.tstr",
  "fileTypes": ["tstr"],
  "patterns": [
    { "include": "#comments" },
    { "include": "#arrows" },
    { "include": "#strings" },
    { "include": "#regex" },
    { "include": "#builtins" },
    { "include": "#http-methods" },
    { "include": "#keywords" },
    { "include": "#status-check" },
    { "include": "#operators" },
    { "include": "#numbers" },
    { "include": "#interpolation" },
    { "include": "#file-ref" },
    { "include": "#constants" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.tstr",
          "match": "//.*$"
        },
        {
          "name": "comment.block.tstr",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "arrows": {
      "patterns": [
        {
          "name": "keyword.control.arrow.input.tstr",
          "match": "-->"
        },
        {
          "name": "keyword.control.arrow.output.tstr",
          "match": "<--"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.tstr",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.tstr",
              "match": "\\\\."
            },
            {
              "name": "variable.other.interpolation.tstr",
              "match": "\\{\\{[^}]+\\}\\}"
            }
          ]
        }
      ]
    },
    "regex": {
      "patterns": [
        {
          "name": "string.regexp.tstr",
          "begin": "(?<=~\\s*|~\\?\\s*|!~\\s*)/",
          "end": "/",
          "patterns": [
            {
              "name": "constant.character.escape.tstr",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "builtins": {
      "patterns": [
        {
          "name": "support.function.builtin.tstr",
          "match": "\\$\\.(uuid|string|randEmail|now|log)\\b"
        },
        {
          "name": "support.function.builtin.tstr",
          "match": "\\$\\.[a-zA-Z_][a-zA-Z0-9_]*"
        }
      ]
    },
    "http-methods": {
      "patterns": [
        {
          "name": "keyword.other.http-method.tstr",
          "match": "\\b(get|post|put|patch|delete)\\s*\\("
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.tstr",
          "match": "\\b(if|else|return)\\b"
        },
        {
          "name": "keyword.other.js.tstr",
          "match": "\\bjs:"
        },
        {
          "name": "storage.type.tstr",
          "match": "\\b(urlPrefix)\\b"
        }
      ]
    },
    "status-check": {
      "patterns": [
        {
          "name": "keyword.operator.status-check.tstr",
          "match": "\\?\\s*(?:\\d+|\\dxx|>=?\\d+|<=?\\d+|\\d+-\\d+)"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.comparison.tstr",
          "match": "==|!=|>=|<=|>|<"
        },
        {
          "name": "keyword.operator.logical.tstr",
          "match": "&&|\\|\\|"
        },
        {
          "name": "keyword.operator.regex.tstr",
          "match": "~\\?|!~|~"
        },
        {
          "name": "keyword.operator.pipe.tstr",
          "match": "\\|(?!\\|)"
        },
        {
          "name": "keyword.operator.assignment.tstr",
          "match": "="
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.tstr",
          "match": "\\b-?\\d+(\\.\\d+)?\\b"
        }
      ]
    },
    "interpolation": {
      "patterns": [
        {
          "name": "variable.other.interpolation.tstr",
          "match": "\\{\\{[^}]+\\}\\}"
        }
      ]
    },
    "file-ref": {
      "patterns": [
        {
          "name": "string.other.file-ref.tstr",
          "match": "@[\\w./_-]+"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.tstr",
          "match": "\\b(null|true|false)\\b"
        }
      ]
    }
  }
}
