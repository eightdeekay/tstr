profile, commerce, req, req2 -->

// Switch URL prefix per service
urlPrefix = profile;
req.body = { name: "Test User" };
r = req.post("/v4/accounts") ? 2xx | "Failed to create account";
accountId = r.id;

urlPrefix = commerce;
req2.body = { accountId: "{{accountId}}" };
r2 = req2.post("/v3/orders") ? 201 | "Failed to create order";
orderId = r2.id;

<-- accountId, orderId
